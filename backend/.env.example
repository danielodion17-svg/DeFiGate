# Copy this file to .env and fill in the values before starting the backend.

# General runtime settings
NODE_ENV=development
PORT=5000

# Database configuration
DATABASE_URL=postgresql://username:password@localhost:5432/defigate_db
# Alternatively, for Supabase-managed Postgres:
# SUPABASE_DATABASE_URL=postgresql://username:password@hostname:5432/postgres
# LOCAL_DATABASE_URL=postgresql://username:password@localhost:5432/defigate_db

# Supabase client configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT / authentication
JWT_SECRET=your-jwt-secret

# Privy wallet provider
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Kotani payment gateway
KOTANI_API_BASE=https://sandbox-api.kotanipay.io/api/v3
KOTANI_API_KEY=your-kotani-api-key
KOTANI_WEBHOOK_SECRET=your-kotani-webhook-secret

# Ramp provider selection
RAMP_PROVIDER=kotani

# Frontend integration
FRONTEND_URL=http://localhost:5000

# Solana configuration
SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com
# Or a comma-separated list of RPC endpoints for production.
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SYSTEM_GAS_WALLET_ADDRESS=your-system-gas-wallet-address
SYSTEM_GAS_WALLET_ENCRYPTED_KEY=your-encrypted-wallet-key-or-empty
SOLANA_GAS_TREASURY_PRIVATE_KEY=your-base64-or-json-secret-key
SOLANA_GAS_TREASURY_ADDRESS=your-treasury-wallet-address
SOLANA_GAS_THRESHOLD=0.01
SOLANA_GAS_REFILL_AMOUNT_SOL=0.05
SOLANA_GAS_AUTO_REFILL=false
SOLANA_GAS_FALLBACK_FEE_SOL=0.000005
SOLANA_RPC_CACHE_TTL_MS=7000
SOLANA_RPC_CONCURRENCY_LIMIT=8
SOLANA_RPC_MAX_RETRY_CYCLES=2
SOLANA_RPC_REQUEST_TIMEOUT_MS=20000

# Background job intervals
DEPOSIT_DETECTOR_INTERVAL_MS=30000
BALANCE_SYNC_INTERVAL_MS=600000
RECONCILIATION_INTERVAL_MS=300000
WALLET_RETRY_INTERVAL_MS=300000
BALANCE_SYNC_SIGNATURE_LIMIT=50
WITHDRAWAL_BROADCAST_ALERT_THRESHOLD_MINUTES=30

# Startup behavior
AUTO_RUN_MIGRATIONS=true
SEQUELIZE_SYNC=false

# Optional system account identifier
SYSTEM_USER_EMAIL=system@example.com
